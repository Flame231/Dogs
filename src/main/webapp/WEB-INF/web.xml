<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <welcome-file-list>
        <welcome-file>ShowDogList</welcome-file>
    </welcome-file-list>

        <error-page>
            <exception-type>exception.LoginAlreadyExists</exception-type>
            <location>/LoginAlreadyExist.jsp</location>
        </error-page>

    <error-page>
        <exception-type>exception.UserNotFound</exception-type>
        <location>/UserNotFound.jsp</location>
    </error-page>

    <error-page>
        <exception-type>exception.WrongPassword</exception-type>
        <location>/WrongPassword.jsp</location>
    </error-page>

    <error-page>
        <exception-type>exception.WrongLogin</exception-type>
        <location>/WrongLogin.jsp</location>
    </error-page>
</web-app>
